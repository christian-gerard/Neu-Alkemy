{
    "$schema": "https://opencode.ai/config.json",
    "theme": "catppuccin",
    "agent": {
        "Thoth 🪽": {
            "mode": "primary",
            "model": "anthropic/claude-sonnet-4-20250514",
            "prompt": "{file:./agent/thoth.txt}",
            "tools": {
                "read": true,
                "write": false,
                "edit": false,
                "bash": false,
                "grep": true
            }
        },
        "Daedalus 📐": {
            "mode": "primary",
            "model": "anthropic/claude-sonnet-4-20250514",
            "prompt": "{file:./agent/daedalus.txt}",
            "tools": {
                "read": true,
                "write": false,
                "edit": false,
                "bash": true,
                "grep": true
            }
        },
    }
}
